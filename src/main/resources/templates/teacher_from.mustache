<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Cargar Docente</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
</head>
<body class="w-full bg-white flex items-center justify-center min-h-screen p-4">
    <div class="w-full bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-2xl">
        
        <a href="/dashboard" class="inline-block bg-gray-600 text-white py-2 px-4 rounded-md hover:bg-gray-700 transition duration-300 mb-6">
            ← Volver al Dashboard
        </a>

        <h1 class="text-3xl font-bold text-center text-white mb-6">Cargar Nuevo Docente</h1>

        {{#errorMessage}}
        <div class="bg-red-200 border border-red-500 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{errorMessage}}</span>
        </div>
        {{/errorMessage}}

        {{#successMessage}}
        <div class="bg-green-200 border border-green-500 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
            <span class="block sm:inline">{{successMessage}}</span>
        </div>
        {{/successMessage}}


        <form action="/teacher/new" method="post" class="space-y-4">

            <div>
                <label for="teacher_dni" class="block text-red-500 text-sm font-medium mb-1">DNI:</label>
                <input type="text" id="teacher_dni" name="teacher_dni" required
                       class="w-full px-4 py-2 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-gray-900 bg-white">
            </div>

            <div>
                <label for="teacher_name" class="block text-red-500 text-sm font-medium mb-1">Nombre:</label>
                <input type="text" id="teacher_name" name="teacher_name" required
                       class="w-full px-4 py-2 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-gray-900 bg-white">
            </div>

            <div>
                <label for="teacher_lastname" class="block text-red-500 text-sm font-medium mb-1">Apellido:</label>
                <input type="text" id="teacher_lastname" name="teacher_lastname" required
                       class="w-full px-4 py-2 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-gray-900 bg-white">
            </div>

            <div>
                <label for="teacher_address" class="block text-red-500 text-sm font-medium mb-1">Dirección:</label>
                <input type="text" id="teacher_address" name="teacher_address"
                       class="w-full px-4 py-2 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-gray-900 bg-white">
            </div>

            <div>
                <label for="teacher_phone" class="block text-red-500 text-sm font-medium mb-1">Teléfono:</label>
                <input type="text" id="teacher_phone" name="teacher_phone"
                       class="w-full px-4 py-2 border border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 text-gray-900 bg-white">
            </div>

            <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                Guardar Docente
            </button>
        </form>
    </div>
</body>
</html>