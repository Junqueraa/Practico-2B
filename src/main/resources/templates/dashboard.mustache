<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Bienvenido</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="w-full bg-white flex items-center justify-center min-h-screen p-4">
    <div class="w-full bg-gray-100 p-8 rounded-lg shadow-xl w-full max-w-2xl">
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Control</h1>

        {{#username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido, <span class="font-semibold text-blue-600">{{username}}</span>!</p>
        {{/username}}
        {{^username}}
        <p class="text-xl text-center text-gray-700 mb-8">¡Bienvenido!</p>
        {{/username}} 

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            
            <div class="w-full bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-2xl">
                <h2 class="text-2xl font-bold text-blue-400 mb-3">Tu Perfil</h2>
                <p class="text-gray-200 mb-4">Gestiona la información de tu cuenta.</p>
                <a href="/profile" class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">Ver Perfil</a>
            </div>

            <div class="w-full bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-2xl">
                <h2 class="text-2xl font-bold text-pink-400 mb-3">Configuraciones</h2>
                <p class="text-gray-200 mb-4">Ajusta las preferencias de tu aplicación.</p>
                <a href="/settings" class="inline-block bg-pink-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Configuración</a>
            </div>

            <div class="w-full bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-2xl">
                <h2 class="text-2xl font-bold text-green-400 mb-3">Cargar un docente</h2>
                <p class="text-gray-200 mb-4">Gestionar el alta de un docente de la universidad.</p>
                <a href="/teacher/new" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Cargar</a>
            </div>
            
             <div class="w-full bg-gray-800 p-8 rounded-lg shadow-lg w-full max-w-2xl">
                <h2 class="text-2xl font-bold text-yellow-400 mb-3">Ver Listado</h2>
                <p class="text-gray-200 mb-4">Muestra todos los usuarios y docentes de la DB.</p>
                <a href="/data/list" class="inline-block bg-yellow-500 text-black py-2 px-4 rounded-md hover:bg-yellow-600 transition duration-300">
                    Ver Datos
                </a>
            </div>

        </div>

        <div class="text-center mt-6">
            <a href="/logout" class="inline-block bg-red-600 text-white py-2 px-6 rounded-md hover:bg-red-700 transition duration-300 text-lg">Cerrar Sesión</a>
        </div>
    </div>
</body>
</html>